# Calyxr Outbound AI Engine — Environment Variables
# Copy this file to .env and fill in your keys
# Never commit .env to GitHub


# ============================================================
#  Calyxr Outbound Intelligence Engine — Environment Config
#  Copy this file to .env and fill in your real values
#  NEVER commit .env to git (it contains secrets)
# ============================================================

# ── Anthropic / Claude AI ────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── HubSpot CRM (optional) ───────────────────────────────────
# HUBSPOT_API_KEY=your-hubspot-private-app-token-here

# ── MySQL Database ───────────────────────────────────────────
# Install MySQL Workbench + MySQL Server, then fill these in:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=outboundai

# # Local server port
# PORT=5000

# # Ngrok Auth Token (get from https://dashboard.ngrok.com)

# # Region (optional but faster if near India)
# NGROK_REGION=in

# # Public URL (will be generated automatically)
# NGROK_URL=https://6dc9-115-244-150-182.ngrok-free.app